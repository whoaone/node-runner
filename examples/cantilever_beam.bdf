$ ----------------------------------------------------------------------
$ Cantilever beam -- SOL 101 (Linear Static)
$
$ Geometry: L = 10 in, 1 in x 1 in square cross section.
$ Material: Al 6061-T6 (E=9.9e6 psi, nu=0.33, rho=0.098 lbm/in^3).
$ Loads: 100 lbf tip force in -Z. Root fully clamped.
$ Mesh: 11 nodes, 10 CBAR elements along +X.
$
$ Analytical tip deflection: delta = P*L^3 / (3*E*I)
$   I = b*h^3/12 = 1*1^3/12 = 0.08333 in^4
$   delta = 100 * 10^3 / (3 * 9.9e6 * 0.08333)
$         = 0.0404 in    (so node 11 T3 should land near -0.04)
$ ----------------------------------------------------------------------
SOL 101
CEND
TITLE = Cantilever beam - SOL 101 (tip force)
SUBCASE 1
  LOAD = 1
  SPC = 1
  DISPLACEMENT(PRINT,PLOT) = ALL
  STRESS(PRINT,PLOT) = ALL
  FORCE(PRINT,PLOT) = ALL
BEGIN BULK
$
$ -------- Material --------
MAT1           1  9.9+6          .33    .098
$
$ -------- Property (1 in x 1 in square bar) --------
$ Free format: PBARL,PID,MID,GROUP(blank=default),TYPE,...,(continuation)DIM1,DIM2
PBARL,1,1,,BAR
,1.,1.
$
$ -------- Nodes (1 in increments along X) --------
GRID           1              0.      0.      0.
GRID           2              1.      0.      0.
GRID           3              2.      0.      0.
GRID           4              3.      0.      0.
GRID           5              4.      0.      0.
GRID           6              5.      0.      0.
GRID           7              6.      0.      0.
GRID           8              7.      0.      0.
GRID           9              8.      0.      0.
GRID          10              9.      0.      0.
GRID          11             10.      0.      0.
$
$ -------- Elements (CBAR with orientation vector along +Y) --------
CBAR           1       1       1       2      0.      1.      0.
CBAR           2       1       2       3      0.      1.      0.
CBAR           3       1       3       4      0.      1.      0.
CBAR           4       1       4       5      0.      1.      0.
CBAR           5       1       5       6      0.      1.      0.
CBAR           6       1       6       7      0.      1.      0.
CBAR           7       1       7       8      0.      1.      0.
CBAR           8       1       8       9      0.      1.      0.
CBAR           9       1       9      10      0.      1.      0.
CBAR          10       1      10      11      0.      1.      0.
$
$ -------- Constraints (root clamped) --------
SPC1           1  123456       1
$
$ -------- Loads (tip force, -Z, 100 lbf) --------
FORCE          1      11       0   -100.      0.      0.      1.
$
ENDDATA
